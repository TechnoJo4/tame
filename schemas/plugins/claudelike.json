{
	"type": "object",
	"required": [
		"maxLines",
		"maxBytes",
		"timeout",
		"shell"
	],
	"properties": {
		"maxLines": {
			"type": "number",
			"default": 2000
		},
		"maxBytes": {
			"type": "number",
			"default": 51200
		},
		"timeout": {
			"type": "number",
			"default": 120000
		},
		"shell": {
			"type": "array",
			"items": {
				"type": "string"
			},
			"default": [
				"bash",
				"-lc"
			]
		},
		"tools": {
			"type": "object",
			"properties": {
				"read": {
					"type": "boolean",
					"default": true
				},
				"write": {
					"type": "boolean",
					"default": true
				},
				"edit": {
					"type": "boolean",
					"default": true
				},
				"bash": {
					"type": "boolean",
					"default": true
				},
				"glob": {
					"type": "boolean",
					"default": true
				},
				"grep": {
					"type": "boolean",
					"default": true
				},
				"skill": {
					"type": "boolean",
					"default": true
				}
			}
		}
	},
	"$schema": "https://json-schema.org/draft/2020-12/schema"
}
