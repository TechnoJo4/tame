{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "rpc-ws config",
	"type": "object",
	"properties": {
		"listen": {
			"type": "object",
			"properties": {
				"hostname": {
					"type": "string"
				},
				"port": {
					"type": "number"
				}
			},
